{
  "name": "advisor",
  "version": "1.0.1",
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "e2e": "playwright test",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "author": "Grafana",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "8.2.0",
    "@grafana/plugin-e2e": "3.8.0",
    "@grafana/tsconfig": "2.1.0",
    "@playwright/test": "1.60.0",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.40",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.2",
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-webpack-plugin": "5.0.3",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "prettier": "3.8.3",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.100.0",
    "sass-loader": "16.0.8",
    "semver": "7.8.2",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.7",
    "terser-webpack-plugin": "5.6.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-merge": "6.0.1",
    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/assistant": "0.1.24",
    "@grafana/data": "13.1.0-27110140411",
    "@grafana/i18n": "13.1.0-27110140411",
    "@grafana/llm": "0.22.1",
    "@grafana/runtime": "13.1.0-27110140411",
    "@grafana/schema": "13.1.0-27110140411",
    "@grafana/ui": "13.1.0-27110140411",
    "@reduxjs/toolkit": "2.12.0",
    "date-fns": "4.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "10.1.0",
    "react-router-dom": "6.30.3",
    "react-use": "17.6.0",
    "rxjs": "7.8.2"
  },
  "packageManager": "npm@11.16.0",
  "overrides": {
    "@grafana/assistant": {
      "@grafana/data": "$@grafana/data",
      "@grafana/runtime": "$@grafana/runtime",
      "@grafana/schema": "$@grafana/schema",
      "@grafana/ui": "$@grafana/ui"
    },
    "@grafana/llm": {
      "@grafana/data": "$@grafana/data",
      "@grafana/runtime": "$@grafana/runtime"
    },
    "dompurify": "3.4.8",
    "immutable": "5.1.5",
    "js-cookie": "3.0.7",
    "uuid": "13.0.2"
